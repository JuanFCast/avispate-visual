# Privy (fase 1: login por correo + wallet embebida en Celo)
NEXT_PUBLIC_PRIVY_APP_ID=cmrtip8jd02g50cl1e089ayyw

# Supabase (fase 2)
NEXT_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-secreta-del-dashboard>

# Privy backend (fase 2): verificar el token en el servidor
PRIVY_APP_SECRET=<app-secret-secreto-de-privy>

# Wallets (fase 3: wagmi + RainbowKit + MiniPay/Farcaster)
# Requerido para WalletConnect y varios conectores de RainbowKit.
# Gratis en https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=<project-id-de-walletconnect-cloud>
# Opcional: RPC propio de Celo (p. ej. Alchemy). Si falta, usa Forno/dRPC.
NEXT_PUBLIC_CELO_RPC_URL=
# Opcional: RPC propio de Ethereum Mainnet. Si falta, usa un RPC público.
NEXT_PUBLIC_MAINNET_RPC_URL=

# Pay-to-play (fase 3): contrato AvispatePot en Celo (se llena tras desplegar)
NEXT_PUBLIC_AVISPATE_POT_ADDRESS=
# Costo por jugada en unidades de USDT (0.10 USDT = 100000, 6 decimales)
NEXT_PUBLIC_AVISPATE_FEE_AMOUNT=100000
